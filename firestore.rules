rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net: default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper: Verify ID complies with standard alphanumeric characters and is bounded
    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper: Validates schema type and boundary constraints for Appointment
    function isValidAppointment(data) {
      return data.patientName is string && data.patientName.size() >= 2 && data.patientName.size() <= 100
          && data.email is string && data.email.size() >= 5 && data.email.size() <= 100
          && data.phone is string && data.phone.size() >= 5 && data.phone.size() <= 30
          // Date is in standard YYYY-MM-DD
          && data.date is string && data.date.size() == 10
          && data.time is string && data.time.size() >= 5 && data.time.size() <= 20
          && data.service is string && data.service.size() <= 50
          && data.status in ['pending', 'confirmed']
          && data.createdAt is string;
    }

    // Helper: Validates schema type and size constraints for ContactRequest
    function isValidContactRequest(data) {
      return data.name is string && data.name.size() >= 2 && data.name.size() <= 100
          && data.email is string && data.email.size() >= 5 && data.email.size() <= 100
          && data.subject is string && data.subject.size() >= 2 && data.subject.size() <= 200
          && data.message is string && data.message.size() >= 2 && data.message.size() <= 2000
          && data.createdAt is string;
    }

    // Appointments Collection Rules
    match /appointments/{appointmentId} {
      allow get: if true;
      allow create: if isValidId(appointmentId) && isValidAppointment(request.resource.data);
      // Let clinical coordinator/staff view and manage bookings
      allow list, update, delete: if true;
    }

    // Contacts Collection Rules
    match /contacts/{contactId} {
      allow create: if isValidId(contactId) && isValidContactRequest(request.resource.data);
      allow read, update, delete: if true;
    }
  }
}
